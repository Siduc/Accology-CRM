# Copy to .env for local overrides (never commit .env)
#   copy .env.example .env

ENV=development
# PORT=8000

# Leave empty to use local SQLite (crm.db)
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/accountant_crm

# Login credentials (required in production; used from .env locally)
AUTH_USERNAME=accountant
AUTH_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string

# Optional
# COMPANIES_HOUSE_API_KEY=
