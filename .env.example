# Copy to .env and fill in values. Never commit .env.

ENV=development

AUTH_USERNAME=accountant
AUTH_PASSWORD=change-me
SESSION_SECRET=dev-only-change-me-in-production

# Companies House — public data (read)
COMPANIES_HOUSE_API_KEY=

# Companies House — OAuth 2.0 API Filing (web application on Developer Hub)
CH_OAUTH_CLIENT_ID=
CH_OAUTH_CLIENT_SECRET=
# Must be a PUBLIC https URL registered on the Hub web client.
# localhost / 127.0.0.1 is blocked by Companies House (403 Forbidden).
# Local dev: use cloudflared/ngrok, e.g.
# CH_OAUTH_REDIRECT_URI=https://YOUR-TUNNEL.trycloudflare.com/oauth/companies-house/callback
CH_OAUTH_REDIRECT_URI=https://your-app.example.com/oauth/companies-house/callback
# Optional overrides (live defaults):
# CH_OAUTH_IDENTITY_BASE=https://identity.company-information.service.gov.uk
# CH_OAUTH_API_BASE=https://api.company-information.service.gov.uk
# CH_OAUTH_EXTRA_SCOPES=https://api.company-information.service.gov.uk/company/{company_number}/registered-office-address.update

# Asana
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=

# Debt chase (default off)
CHASE_LIVE_MODE=false
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
PRACTICE_NAME=Accologise Practice
